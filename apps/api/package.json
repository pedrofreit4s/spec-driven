{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "check-types": "tsc --noEmit",
    "db:generate": "pnpm --filter @spec-driven/db db:generate",
    "db:migrate": "pnpm --filter @spec-driven/db db:migrate",
    "db:studio": "pnpm --filter @spec-driven/db db:studio"
  },
  "dependencies": {
    "@spec-driven/db": "workspace:*",
    "@spec-driven/http": "workspace:*",
    "@spec-driven/logger": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "pino-pretty": "^13.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
