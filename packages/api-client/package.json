{
  "name": "@spec-driven/api-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "codegen": "openapi-typescript http://localhost:3001/openapi.json -o src/generated/api.d.ts"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openapi-typescript": "^7.6.1",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
